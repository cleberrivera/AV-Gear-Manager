# ─── Database (Docker Compose default — just run: docker compose up -d) ──────
DATABASE_URL=mysql://avmanager:avmanager123@localhost:3306/av_gear_manager

# ─── Auth (JWT) — auto-generated by setup, change in production ─────────────
JWT_SECRET=your-secret-key-change-this-in-production
JWT_EXPIRES_IN=7d

# ─── First admin (use this email when registering to get admin role) ─────────
ADMIN_EMAIL=admin@avmanager.com

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3000

# ─── Email (SMTP) — optional ─────────────────────────────────────────────────
# If not configured, emails go to Ethereal (test mode)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@email.com
# SMTP_PASS=your-app-password
# SMTP_FROM=AV Gear Manager <your@email.com>
